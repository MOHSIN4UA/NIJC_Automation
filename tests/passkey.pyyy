from playwright.sync_api import sync_playwright
import os

def test_passkey_login():
    with sync_playwright() as p:
        # 👉 Use persistent browser context as requested
        user_data_dir = "./user_data"
        
        # Ensure the directory exists
        if not os.path.exists(user_data_dir):
            os.makedirs(user_data_dir)
            
        context = p.chromium.launch_persistent_context(
            user_data_dir,
            headless=False,
            args=["--start-maximized"]
        )
        page = context.pages[0] if context.pages else context.new_page()
        
        # 👉 Log console and network for debugging
        page.on("console", lambda msg: print(f"[Browser Console] {msg.type}: {msg.text}"))
        
        def handle_response(response):
            if "begin" in response.url or "login" in response.url:
                print(f"[Network] {response.status} {response.url}")
        
        page.on("response", handle_response)

        # 👉 Create CDP session
        client = context.new_cdp_session(page)

        # 👉 Enable WebAuthn
        client.send("WebAuthn.enable")
        
        # 👉 Add virtual authenticator
        # We'll try 'internal' first as it's common for "built-in" passkey scenarios
        authenticator_id = client.send("WebAuthn.addVirtualAuthenticator", {
            "options": {
                "protocol": "ctap2",
                "transport": "internal", 
                "hasResidentKey": True,
                "hasUserVerification": True,
                "isUserVerified": True
            }
        })["authenticatorId"]
        
        # 👉 Enable automatic presence simulation
        client.send("WebAuthn.setAutomaticPresenceSimulation", {
            "authenticatorId": authenticator_id,
            "enabled": True
        })

        # 👉 Go to your URL
        page.goto("https://qa-app.yieldz.net/auth/custom/sign-options")
        page.wait_for_load_state("networkidle")

        # 👉 Click LOG IN tab
        page.locator('button[data-testid="qa-1"]').filter(has_text="Log In").click()
        page.wait_for_timeout(1000)
        
        # 👉 Click CONTINUE WITH PASSKEY option
        page.locator('button[data-testid="qa-0"]').filter(has_text="Continue with Passkey").click()
        page.wait_for_timeout(1000)

        # 👉 Click final CONTINUE WITH PASSKEY button (teal)
        final_btn = page.locator('button[data-testid="qa-continue-with-passkey"]')
        final_btn.wait_for(state="visible", timeout=10000)
        
        # Ensure focus
        page.bring_to_front()
        final_btn.focus()
        page.wait_for_timeout(1000)
        
        final_btn.click()

        # 👉 THE INTERESTING THING: Proceed through the native browser dialog
        # We wait for the dialog to appear, then type the PIN 111000 and press Enter
        print("[Passkey] Waiting for native dialog...")
        page.wait_for_timeout(5000)
        page.keyboard.type("111000")
        page.wait_for_timeout(500)
        page.keyboard.press("Enter")
        print("[Passkey] Typed PIN and pressed Enter on native dialog")

        # 👉 Wrap up
        page.wait_for_timeout(5000)
        print(f"[Passkey] Final URL: {page.url}")
        
        context.close()

if __name__ == "__main__":
    test_passkey_login()